def dect_sys():
    global Temperatura_inicial_cpu
    global Temperatura_maxima_cpu
    global Procesador
    global Memoria_ram
    global Disco_duro
    global temperatura_cpu

    Procesador = psutil.cpu_percent (interval = 1) #Para saber cuanto porciento del procesador se esta utilizando (Le he puesto tambien un intervalo de 1 seg  ya que solo es para ver cuanto trabajo la CPU por segundo )
    Memoria_ram = psutil.virtual_memory ().percent #Para saber cuanto porciento de la RAM se esta utilizando
    Disco_duro = psutil.disk_usage ('/').percent #Para saber cuanto porciento del Disco duro se esta utilizando
    temperatura_cpu = 0 #guardara la temperatura actual de la cpu
    temperaturas = psutil.sensors_temperatures ()
    

    
    try:
        temperatura_cpu = temperaturas['coretemp'][0].current #temperatura actual de la CPU
    except:
        temperatura_cpu = 0 #evita errores con el coretemp
    
if Temperatura_inicial_cpu is none : #al arrancar
    Temperatura_inicial_cpu = temperatura_cpu #la variable cojera la primera temperatura de la CPU

