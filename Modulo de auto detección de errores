def run(cmd, check=True): # funcion para ejecutar comandos en la terminal Uso: run("ls -l")
    return subprocess.run(cmd, shell=True, check=check, capture_output=True, text=True)


def dect_servicios():
    #con run() haz un system status a cada servicio y captura el output si esta funcionando bien hz un print ok si no intenta reiniciar si sigue igual despues del reinicio haaz una ventana emergente con error
