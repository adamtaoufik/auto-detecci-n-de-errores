    else: # sino
        print(f"Temperatura inicial de CPU: ({Temperatura_inicial_cpu}) ") #pues solo dara la temperatura


if temperatura_cpu > Temperatura_maxima_cpu: #para coger la temperatura máxima a la que haya llegado la CPU
